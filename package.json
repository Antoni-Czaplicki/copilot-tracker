{
  "name": "copilot-tracker-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "compile": "pnpm --filter ./apps/extension compile",
    "db:generate": "pnpm --filter @copilot-tracker/web db:generate",
    "db:migrate": "pnpm --filter @copilot-tracker/web db:migrate",
    "db:studio": "pnpm --filter @copilot-tracker/web db:studio",
    "dev:web": "pnpm --filter @copilot-tracker/web dev",
    "format": "prettier . --write",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter ./apps/extension test",
    "test:web": "pnpm --filter @copilot-tracker/web test",
    "typecheck": "pnpm -r typecheck"
  },
  "prettier": "@solvro/config/prettier",
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.9",
    "@solvro/config": "^2.3.4",
    "@types/node": "~26.0.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "packageManager": "pnpm@11.7.0"
}
