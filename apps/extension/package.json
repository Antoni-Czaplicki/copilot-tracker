{
  "name": "copilot-tracker",
  "displayName": "Copilot tracker",
  "version": "0.0.1",
  "description": "Track your copilot tokens per branch or assign them manually",
  "categories": [
    "Other"
  ],
  "publisher": "antoni-czaplicki",
  "license": "MIT",
  "homepage": "https://github.com/Antoni-Czaplicki/copilot-tracker#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Antoni-Czaplicki/copilot-tracker.git",
    "directory": "apps/extension"
  },
  "bugs": {
    "url": "https://github.com/Antoni-Czaplicki/copilot-tracker/issues"
  },
  "main": "./out/extension.js",
  "scripts": {
    "build": "pnpm run compile",
    "compile": "tsc -p ./",
    "lint": "eslint src",
    "package": "vsce package --no-dependencies",
    "pretest": "pnpm run compile && pnpm run lint",
    "test": "vscode-test",
    "typecheck": "tsc -p ./ --noEmit",
    "vscode:prepublish": "pnpm run compile",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "commands": [
      {
        "command": "copilot-tracker.setTask",
        "title": "Set Current Task",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.useBranchTask",
        "title": "Use Branch as Task",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.syncCopilotSessions",
        "title": "Sync Copilot OTel Now",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.signIn",
        "title": "Sign In",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.openDashboard",
        "title": "Open Dashboard",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.showContext",
        "title": "Show Current Context",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.showLogs",
        "title": "Show Logs",
        "category": "Copilot Tracker"
      }
    ],
    "configuration": {
      "title": "Copilot Tracker",
      "properties": {
        "copilot-tracker.serverUrl": {
          "type": "string",
          "default": "http://localhost:3737",
          "description": "Copilot Tracker server URL. Set this in user settings; workspace values are ignored for token safety."
        },
        "copilot-tracker.otelFilePath": {
          "type": "string",
          "default": "",
          "description": "Optional path for the Copilot Chat OTel JSONL file. Leave empty to use extension global storage."
        },
        "copilot-tracker.syncIntervalSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "description": "Fallback polling interval for detecting Copilot OTel file changes."
        },
        "copilot-tracker.showCurrentSessionTokensInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show current Copilot chat session token usage in the status bar."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:copilot-tracker.setTask",
    "onCommand:copilot-tracker.useBranchTask",
    "onCommand:copilot-tracker.syncCopilotSessions",
    "onCommand:copilot-tracker.signIn",
    "onCommand:copilot-tracker.openDashboard",
    "onCommand:copilot-tracker.showContext",
    "onCommand:copilot-tracker.showLogs"
  ],
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~26.0.1",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.2.0",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "engines": {
    "vscode": "^1.125.0"
  }
}
