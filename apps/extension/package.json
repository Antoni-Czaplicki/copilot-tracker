{
  "name": "@copilot-tracker/extension",
  "displayName": "Copilot tracker",
  "version": "0.0.1",
  "description": "Track your copilot tokens per branch or assign them manually",
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "build": "pnpm run compile",
    "compile": "tsc -p ./",
    "lint": "eslint src",
    "pretest": "pnpm run compile && pnpm run lint",
    "test": "vscode-test",
    "typecheck": "tsc -p ./ --noEmit",
    "vscode:prepublish": "pnpm run compile",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "commands": [
      {
        "command": "copilot-tracker.setTask",
        "title": "Set Current Task",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.useBranchTask",
        "title": "Use Branch as Task",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.syncCopilotSessions",
        "title": "Sync Copilot Sessions Now",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.openDashboard",
        "title": "Open Dashboard",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.showContext",
        "title": "Show Current Context",
        "category": "Copilot Tracker"
      },
      {
        "command": "copilot-tracker.showLogs",
        "title": "Show Logs",
        "category": "Copilot Tracker"
      }
    ],
    "configuration": {
      "title": "Copilot Tracker",
      "properties": {
        "copilot-tracker.serverUrl": {
          "type": "string",
          "default": "http://localhost:3737",
          "description": "Copilot Tracker server URL."
        },
        "copilot-tracker.readVsCodeChatStorage": {
          "type": "boolean",
          "default": true,
          "description": "Read VS Code internal chat session metadata from workspaceStorage."
        },
        "copilot-tracker.chatStoragePath": {
          "type": "string",
          "default": "",
          "description": "Optional override for VS Code workspaceStorage path. Leave empty to use the platform default."
        },
        "copilot-tracker.syncIntervalSeconds": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "description": "Fallback polling interval for detecting Copilot chat session file changes."
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:copilot-tracker.setTask",
    "onCommand:copilot-tracker.useBranchTask",
    "onCommand:copilot-tracker.syncCopilotSessions",
    "onCommand:copilot-tracker.openDashboard",
    "onCommand:copilot-tracker.showContext",
    "onCommand:copilot-tracker.showLogs"
  ],
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~26.0.1",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "engines": {
    "vscode": "^1.125.0"
  }
}
