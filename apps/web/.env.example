AZURE_DEVOPS_CLIENT_ID=replace-with-azure-app-client-id
AZURE_DEVOPS_CLIENT_SECRET=replace-with-azure-app-client-secret
AZURE_DEVOPS_ORG=replace-with-azure-devops-organization
AZURE_DEVOPS_TENANT_ID=organizations
ADMIN_AZURE_DEVOPS_LOGINS=your-work-email@example.com

GITHUB_COPILOT_BILLING_TOKEN=
GITHUB_COPILOT_BILLING_SCOPE_TYPE=
GITHUB_COPILOT_BILLING_SCOPE=
